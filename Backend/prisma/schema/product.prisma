model Product {
  id              String          @id @default(uuid())
  name            String
  slug            String          @unique
  description     String
  gender          String

  brandName       String
  brandOrigin     String

  itemId          String
  item            Item           @relation(fields: [itemId], references: [id])

  currentPrice    Float
  oldPrice        Float?
  discountPercent Int?

  thumbnail       String
  images          ProductImage[]

  stock           Int             @default(0)
  sold            Int             @default(0)

  aiStylistInfo   Json?

  isFlashSale     Boolean         @default(false)
  flashStartAt    DateTime?
  flashExpiresAt  DateTime?
  flashDiscount   Float?

  timerLabel      String?

  variants        Variant[]
  reviews         Review[]

  orderItems      OrderItem[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}
