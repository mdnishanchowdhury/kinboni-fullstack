model Order {
  id          String       @id @default(uuid())
  userId      String

  addressId   String
  address     Address     @relation(fields: [addressId], references: [id])

  totalAmount Float
  status      OrderStatus  @default(PENDING)

  payment     Payment?
  orderItems  OrderItem[]

  createdAt   DateTime     @default(now())

  @@index([userId])
}